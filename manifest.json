{
  "manifest_version": 3,
  "name": "Dumb Abo (für derstandard.at)",
  "version": "1.0.1",
  "description": "Unlocks the paywalled comment sort tabs (Plus, Minus, Älteste, …) in derstandard.at's forum.",
  "browser_specific_settings": {
    "gecko": {
      "id": "dumb-abo@dstat-tools",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "16": "icons/dumb-abo-16.png",
    "32": "icons/dumb-abo-32.png",
    "48": "icons/dumb-abo-48.png",
    "96": "icons/dumb-abo-96.png",
    "128": "icons/dumb-abo-128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.derstandard.at/story/*"],
      "js": ["src/inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.derstandard.at/story/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ]
}
